<div role="tabpanel" class="tab-pane" id="pbta">
  <p>Select your Playbook in the Groups tab first, then click below to initialize your stats.</p>
  <button class="btn btn-primary" {{action "initStats"}}>Initialize Playbook Stats</button>

  <hr/>

  <p>Choose your Gimmick:</p>
  <select onchange={{action "selectGimmick" value="target.value"}}>
    <option value="">-- Pick a Gimmick --</option>
    {{#each chargenData.gimmicks as |gimmick|}}
      <option value={{gimmick.name}}>{{gimmick.name}} — {{gimmick.desc}}</option>
    {{/each}}
  </select>
</div>
