{{#if (eq activeTab 'heroesguild')}}
  <div class="heroesguild-sheet">
    {{#if char.heroesguild}}
      <div class="hg-header">
        <span class="hg-role">{{char.heroesguild.role}}</span>
        <span class="hg-gimmick">{{char.heroesguild.gimmick}}</span>
      </div>
      <div class="hg-stats">
        {{#each-in char.heroesguild.stats as |stat value|}}
          <div class="hg-stat">
            <div class="hg-stat-name">{{stat}}</div>
            <div class="hg-stat-value {{if (gte value 0) 'positive' 'negative'}}">
              {{if (gte value 0) '+' ''}}{{value}}
            </div>
          </div>
        {{/each-in}}
      </div>
      <div class="hg-tracks">
        <div class="hg-track">
          <span class="label">Stress</span>
          <div class="track-bar">
            {{#each char.heroesguild.stress_pips as |pip|}}
              <div class="pip {{if pip.filled 'filled'}}"></div>
            {{/each}}
          </div>
        </div>
        <div class="hg-track">
          <span class="label">XP</span>
          <div class="track-bar">
            {{#each char.heroesguild.xp_pips as |pip|}}
              <div class="pip {{if pip.filled 'filled'}}"></div>
            {{/each}}
          </div>
        </div>
      </div>
      <div class="hg-moves">
        <h4>Moves</h4>
        {{#each char.heroesguild.all_moves as |move|}}
          <div class="hg-move">
            <strong>{{move.name}}</strong>
            <p>{{move.desc}}</p>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p class="no-data">This character hasn't set their Playbook yet.</p>
    {{/if}}
  </div>
{{/if}}
