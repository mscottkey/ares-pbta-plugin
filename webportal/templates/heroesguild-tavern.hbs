<div class="container heroesguild-tavern-hud">

  <div class="hg-hud-header">
    <h1>Tavern Night</h1>
    <span class="hg-status-badge hg-status-{{model.status}}">{{model.status}}</span>
    <span class="hg-vibe-pool">Vibe Pool: {{model.vibe_pool}}</span>
  </div>

  {{#if (eq model.status "active")}}

    {{! ── Personal Status ── }}
    <div class="hg-personal-section">
      <h2>Your Status</h2>
      <div class="hg-track-row">
        <span class="hg-track-label">Stress</span>
        <div class="hg-pip-track">
          {{#each model.stress_pips as |pip|}}
            <div class="hg-pip {{if pip.filled 'filled stress'}}"></div>
          {{/each}}
        </div>
        <span class="hg-track-count">{{model.viewer_stress}}/{{model.stress_max}}</span>
      </div>
      <div class="hg-track-row">
        <span class="hg-track-label">Inebriation</span>
        <div class="hg-pip-track">
          {{#each model.ineb_pips as |pip|}}
            <div class="hg-pip {{if pip.filled 'filled ineb'}}"></div>
          {{/each}}
        </div>
        <span class="hg-track-count">
          {{model.viewer_inebriation}}/{{model.viewer_ineb_limit}}
        </span>
      </div>
      <div class="hg-track-row">
        <span class="hg-track-label">Vibe</span>
        <span class="hg-vibe-value">{{model.viewer_vibe}}</span>
      </div>
    </div>

    {{! ── Actions ── }}
    <div class="hg-actions-section">
      <h2>Actions</h2>
      <div class="hg-action-buttons">
        <button class="btn btn-primary" {{action 'doCarouse'}}>
          Carouse (+Heart)
        </button>
        <button class="btn btn-default" {{action 'doImbibe'}}>
          Imbibe
        </button>
        <button class="btn btn-default" {{action 'doSober'}}>
          Sober Up
        </button>
        <button class="btn btn-default" {{action 'doInvestigate'}}>
          Investigate (+Cunning)
        </button>
      </div>
    </div>

    {{! ── Active Leads ── }}
    {{#if model.viewer_leads.length}}
      <div class="hg-leads-section">
        <h2>Your Active Leads</h2>
        <table class="table">
          <thead>
            <tr><th>Lead</th><th>Clues</th><th></th></tr>
          </thead>
          <tbody>
            {{#each model.viewer_leads as |lead|}}
              <tr>
                <td>{{lead.title}}</td>
                <td>{{lead.clues_gathered}}/{{lead.clues_needed}}</td>
                <td>
                  <button class="btn btn-sm btn-default"
                          {{action 'addClue' lead.id}}>
                    +Clue
                  </button>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    {{! ── Participants ── }}
    <div class="hg-participants-section">
      <h2>At the Table</h2>
      <table class="table">
        <thead>
          <tr><th>Name</th><th>Inebriation</th><th>Vibe</th><th>Stress</th></tr>
        </thead>
        <tbody>
          {{#each model.participants as |p|}}
            <tr>
              <td>{{p.name}}</td>
              <td>{{p.inebriation}}/{{p.ineb_limit}}</td>
              <td>{{p.vibe}}</td>
              <td>{{p.stress}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{! ── GM Controls ── }}
    {{#if model.is_admin}}
      <div class="hg-gm-section">
        <h2>GM Controls</h2>
        <button class="btn btn-danger" {{action 'closeNight'}}>
          Close Tavern Night
        </button>
      </div>
    {{/if}}

  {{else}}
    <p>This tavern night is {{model.status}}.</p>
  {{/if}}

</div>
