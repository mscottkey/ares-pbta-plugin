<div class="container heroesguild-board">

  <h1>Heroes Guild — The Board</h1>

  {{! ── Active Runs ── }}
  {{#if model.active_runs.length}}
    <div class="hg-board-section hg-active-runs">
      <h2>Active Dungeon Runs</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Contract</th>
            <th>Modifier</th>
            <th>Doom</th>
            <th>Progress</th>
            <th>Party</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each model.active_runs as |run|}}
            <tr>
              <td><strong>{{run.contract_title}}</strong></td>
              <td>
                {{#if run.modifier}}
                  <span class="hg-modifier-badge">{{run.modifier}}</span>
                {{/if}}
              </td>
              <td>
                <span class="hg-doom-label hg-doom-{{run.doom_label}}">
                  {{run.doom_level}}/10 {{run.doom_label}}
                </span>
              </td>
              <td>{{run.progress}}/{{run.progress_max}}</td>
              <td>{{run.party}}</td>
              <td>
                <a href="/heroesguild/dungeon/{{run.id}}" class="btn btn-sm btn-default">
                  View HUD
                </a>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{/if}}

  {{! ── Active Leads ── }}
  <div class="hg-board-section hg-leads">
    <h2>
      Active Investigations
      <span class="hg-lead-cap {{if model.board_full 'hg-cap-full'}}">
        {{model.lead_count}}/{{model.lead_cap}}
      </span>
    </h2>
    {{#if model.board_full}}
      <div class="alert alert-warning">
        The board is full. Existing leads must be resolved before new
        investigations can be opened.
      </div>
    {{/if}}
    {{#if model.leads.length}}
      <table class="table">
        <thead>
          <tr>
            <th>Lead</th>
            <th>Posted By</th>
            <th>Clues</th>
            <th>Notes</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each model.leads as |lead|}}
            <tr class="{{if lead.idle 'hg-lead-idle'}}">
              <td>
                <strong>{{lead.title}}</strong>
                <p class="small text-muted">{{lead.description}}</p>
                {{#if lead.idle}}
                  <span class="hg-idle-badge">Idle {{lead.inactive_days}}d</span>
                {{/if}}
              </td>
              <td>{{lead.investigator}}</td>
              <td>
                <div class="hg-clue-track">
                  {{lead.clues_gathered}}/{{lead.clues_needed}}
                </div>
              </td>
              <td>
                {{#if lead.job_url}}
                  <a href="{{lead.job_url}}">
                    {{lead.reply_count}} note{{if (gt lead.reply_count 1) 's'}}
                  </a>
                {{else}}
                  —
                {{/if}}
              </td>
              <td>
                {{#if lead.can_clue}}
                  <button class="btn btn-sm btn-default"
                    {{action 'addClue' lead.id}}>
                    +Clue
                  </button>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="text-muted">
        No active investigations. Roll +investigate during a Tavern Night to generate a lead.
      </p>
    {{/if}}
  </div>

  {{! ── Posted Contracts ── }}
  <div class="hg-board-section hg-contracts">
    <h2>Posted Contracts</h2>
    {{#if model.contracts.length}}
      <table class="table">
        <thead>
          <tr>
            <th>Contract</th>
            <th>Modifier</th>
          </tr>
        </thead>
        <tbody>
          {{#each model.contracts as |contract|}}
            <tr>
              <td>
                <strong>{{contract.title}}</strong>
                <p class="small text-muted">{{contract.description}}</p>
              </td>
              <td>
                <span class="hg-modifier-badge">{{contract.modifier}}</span>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
      <p class="text-muted small">
        To run a contract, coordinate via the Events system and use
        Start Dungeon Run from your scene's Play menu.
      </p>
    {{else}}
      <p class="text-muted">No contracts posted. Investigate to generate leads that become contracts.</p>
    {{/if}}
  </div>

  {{! ── Recent History ── }}
  {{#if model.recent.length}}
    <div class="hg-board-section hg-history">
      <h2>Recent History</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Contract</th>
            <th>Result</th>
            <th>Doom Reached</th>
          </tr>
        </thead>
        <tbody>
          {{#each model.recent as |run|}}
            <tr>
              <td>{{run.contract_title}}</td>
              <td>
                <span class="hg-result-{{run.status}}">
                  {{if (eq run.status 'complete') '✓ Cleared' '✗ Failed'}}
                </span>
              </td>
              <td>{{run.doom_level}}/10</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{/if}}

</div>
