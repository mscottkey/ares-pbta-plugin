<div class="container heroesguild-dungeon-hud">

  {{! ── Header ── }}
  <div class="hg-hud-header">
    {{#if model.contract}}
      <h1>{{model.contract.title}}</h1>
      <span class="hg-modifier-badge">{{model.contract.modifier}}</span>
      <p class="hg-contract-desc">{{model.contract.description}}</p>
    {{else}}
      <h1>Dungeon Run — Pending</h1>
      <p>Select a contract below to begin.</p>
    {{/if}}
    <span class="hg-status-badge hg-status-{{model.status}}">{{model.status}}</span>
  </div>

  {{! ── Contract Selection (pending state only) ── }}
  {{#if (eq model.status "pending")}}
    <div class="hg-contract-select">
      <h2>Available Contracts</h2>
      {{#if model.posted_contracts.length}}
        <table class="table">
          <thead>
            <tr><th>Contract</th><th>Modifier</th><th></th></tr>
          </thead>
          <tbody>
            {{#each model.posted_contracts as |contract|}}
              <tr>
                <td>
                  <strong>{{contract.title}}</strong>
                  <p class="small">{{contract.description}}</p>
                </td>
                <td><span class="hg-modifier-badge">{{contract.modifier}}</span></td>
                <td>
                  <button class="btn btn-primary btn-sm"
                          {{action 'selectContract' contract.id}}>
                    Take This Contract
                  </button>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      {{else}}
        <p>No contracts posted on the board. Use +contract/post in-game to add one.</p>
      {{/if}}
    </div>
  {{/if}}

  {{! ── Active Run ── }}
  {{#if (eq model.status "active")}}
    <div class="hg-hud-body">

      {{! Doom Clock }}
      <div class="hg-doom-section">
        <h2>Doom Clock</h2>
        <div class="hg-doom-track">
          {{#each model.doom_pips as |pip|}}
            <div class="hg-doom-pip {{if pip.filled 'filled'}} {{if pip.threshold pip.threshold}}">
              {{pip.label}}
            </div>
          {{/each}}
        </div>
        <div class="hg-doom-status hg-doom-{{model.doom_label}}">
          {{model.doom_level}}/10 — {{model.doom_label}}
        </div>
      </div>

      {{! Progress }}
      <div class="hg-progress-section">
        <h2>Progress</h2>
        <div class="hg-progress-track">
          {{#each model.progress_pips as |pip|}}
            <div class="hg-progress-pip {{if pip.filled 'filled'}}"></div>
          {{/each}}
        </div>
        <div class="hg-progress-label">{{model.progress}}/{{model.progress_max}}</div>
      </div>

      {{! Party Roster }}
      <div class="hg-party-section">
        <h2>Party</h2>
        <table class="table">
          <thead>
            <tr><th>Name</th><th>Role</th><th>Stress</th></tr>
          </thead>
          <tbody>
            {{#each model.participants as |p|}}
              <tr>
                <td>{{p.name}}</td>
                <td>{{p.role}}</td>
                <td>
                  <div class="hg-stress-track">
                    {{#each p.stress_pips as |pip|}}
                      <div class="hg-stress-pip {{if pip.filled 'filled'}}"></div>
                    {{/each}}
                  </div>
                  {{p.stress}}/{{p.stress_max}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      {{! Move Roller }}
      <div class="hg-move-section">
        <h2>Roll a Move</h2>
        <div class="hg-move-controls">
          <select onchange={{action 'selectMove' value="target.value"}}>
            <option value="">— Select a Move —</option>
            {{#each model.viewer_moves as |move|}}
              <option value="{{move.name}}">{{move.name}} (+{{move.stat}})</option>
            {{/each}}
          </select>
          <button class="btn btn-primary"
                  {{action 'rollMove'}}
                  disabled={{not selectedMove}}>
            Roll Move
          </button>
        </div>
        {{#if selectedMove}}
          {{#each model.viewer_moves as |move|}}
            {{#if (eq move.name selectedMove)}}
              <p class="hg-move-desc">{{move.desc}}</p>
            {{/if}}
          {{/each}}
        {{/if}}
      </div>

      {{! GM Controls }}
      {{#if model.is_admin}}
        <div class="hg-gm-section">
          <h2>GM Controls</h2>
          <div class="hg-gm-buttons">
            <button class="btn btn-danger"  {{action 'advanceDoom'}}>Advance Doom</button>
            <button class="btn btn-warning" {{action 'randomThreat'}}>Random Threat</button>
            <button class="btn btn-success" {{action 'markProgress' 1}}>+1 Progress</button>
            <button class="btn btn-success" {{action 'markProgress' 2}}>+2 Progress</button>
            <button class="btn btn-default" {{action 'endRun'}}>End Run</button>
          </div>
        </div>
      {{/if}}

    </div>
  {{/if}}

  {{! ── Complete / Failed Summary ── }}
  {{#if (or (eq model.status "complete") (eq model.status "failed"))}}
    <div class="hg-run-summary">
      <h2>Run {{capitalize model.status}}</h2>
      <p>Doom reached: {{model.doom_level}}/10</p>
      <p>Progress: {{model.progress}}/{{model.progress_max}}</p>
    </div>
  {{/if}}

</div>
