{{#if this.chargenData}}
  {{#if @char.role}}
    <p><strong>Playbook:</strong> {{@char.role}} &mdash; stats initialized.</p>
  {{else}}
    <p>Select your Playbook in the Groups tab first, then click below to initialize your stats.</p>
    <button class="btn btn-primary" {{on "click" this.initStats}}>Initialize Playbook Stats</button>
  {{/if}}

  <hr />

  <p><strong>Gimmick:</strong>
    {{#if @char.gimmick}}
      {{@char.gimmick}}
    {{else}}
      None selected.
    {{/if}}
  </p>

  <select onchange={{this.selectGimmickFromEvent}}>
    <option value="">-- Pick a Gimmick --</option>
    {{#each this.chargenData.gimmicks as |gimmick|}}
      <option value={{gimmick.name}} selected={{eq gimmick.name @char.gimmick}}>
        {{gimmick.name}} - {{gimmick.desc}}
      </option>
    {{/each}}
  </select>
{{/if}}
