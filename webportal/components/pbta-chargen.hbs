{{#if this.chargenData}}
  {{#if this.chargenData.char_role}}
    <p><strong>Playbook:</strong> {{this.chargenData.char_role}} &mdash; stats initialized.</p>
  {{else}}
    <p>Select your Playbook in the Groups tab first, then click below to initialize your stats.</p>
    <button class="btn btn-primary" {{on "click" this.initStats}}>Initialize Playbook Stats</button>
  {{/if}}

  <hr />

  <h4>Choose Your Gimmick</h4>
  <p>{{this.chargenData.gimmick_explainer}}</p>

  {{#each this.chargenData.gimmicks as |gimmick|}}
    <div class="card mb-3 {{if (eq gimmick.name this.chargenData.char_gimmick) "border-primary"}}">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h5 class="card-title mb-1">{{gimmick.name}}</h5>
            <p class="card-text mb-1"><strong>{{gimmick.desc}}</strong></p>
            <p class="card-text text-muted">{{gimmick.lore}}</p>
          </div>
          <div class="ms-3">
            {{#if (eq gimmick.name this.chargenData.char_gimmick)}}
              <span class="badge bg-primary">Selected</span>
            {{else}}
              <button class="btn btn-outline-primary btn-sm" {{on "click" (fn this.selectGimmick gimmick.name)}}>
                Select
              </button>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  {{/each}}
{{/if}}
